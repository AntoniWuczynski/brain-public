# Copy this file to `.env` (which is git-ignored) and fill in your values.
# Loaded automatically by scripts/ingest.py; nothing else uses it.

# Required to enable the LLM summarizer (Summary + Key points sections of
# generated index notes). Without this, those sections show placeholders
# but ingestion still works.
ANTHROPIC_API_KEY=

# Optional: set to "1" to skip summarization even when the API key is set.
# BRAIN_SKIP_SUMMARY=1

# Optional: override the device MinerU uses for inference.
# Defaults to mps on Apple Silicon, cuda if available, otherwise cpu.
# MINERU_DEVICE_MODE=mps

# Optional: switch model source if Hugging Face is blocked.
# Default: huggingface. Alternative: modelscope (Alibaba mirror).
# MINERU_MODEL_SOURCE=modelscope
