{
  "name": "brain",
  "build": { "dockerfile": "Dockerfile" },
  "containerEnv": {
    "UV_LINK_MODE": "copy",
    "PYTHONUNBUFFERED": "1"
  },
  "mounts": [
    "source=brain-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source=brain-mineru-models,target=/home/vscode/.cache/magic-pdf,type=volume"
  ],
  "postCreateCommand": "uv sync --frozen || uv sync",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "tamasfe.even-better-toml"
      ]
    }
  }
}
